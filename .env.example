# Copie para .env na raiz do projeto (junto a package.json).

# SendGrid — remetente tem de estar verificado no painel
SENDGRID_API_KEY=
# Preferencial (como no teu outro projecto)
SENDGRID_FROM=Receitas GC <email-verificado@seudominio.com>
# Alternativa aceite pelo app se SENDGRID_FROM estiver vazio
# MAIL_FROM=
