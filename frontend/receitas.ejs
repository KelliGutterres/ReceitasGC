<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Receitas</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="page-app">
  <%- include('partials/header-app', { userNome: userNome, currentPage: 'lista' }) %>

  <main class="app-main">
    <div class="page-head page-head-split">
      <div>
        <h1 class="page-title">Receitas cadastradas</h1>
      </div>
      <div class="page-head-actions">
        <a href="<%= pdfHref %>" class="btn-secondary btn-export" target="_blank" rel="noopener">Exportar PDF</a>
        <a href="/receitas/nova" class="btn-primary">+ Nova receita</a>
      </div>
    </div>

    <section class="filter-panel" aria-label="Filtros da listagem">
      <form method="get" action="/receitas" class="filter-form">
        <div class="filter-fields">
          <label class="filter-field">
            <span class="filter-label">Tipo</span>
            <select name="tipo_receita">
              <option value="" <%= !filters.tipo_receita ? 'selected' : '' %>>Todos</option>
              <option value="doce" <%= filters.tipo_receita === 'doce' ? 'selected' : '' %>>Doce</option>
              <option value="salgada" <%= filters.tipo_receita === 'salgada' ? 'selected' : '' %>>Salgada</option>
            </select>
          </label>
          <label class="filter-field">
            <span class="filter-label">Data de criação</span>
            <input type="date" name="data_criacao" value="<%= filters.data_criacao %>" title="Filtra receitas registradas nesta data" />
          </label>
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn-primary btn-sm">Aplicar filtros</button>
          <a href="/receitas" class="btn-secondary btn-sm">Limpar</a>
        </div>
      </form>
    </section>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <p class="flash flash-<%= flash.type %>"><%= flash.message %></p>
    <% } %>

    <% if (!receitas.length && !filterEmpty) { %>
      <div class="empty-state">
        <p>Nenhuma receita ainda.</p>
        <a href="/receitas/nova" class="btn-primary">Cadastrar a primeira</a>
      </div>
    <% } else if (!receitas.length && filterEmpty) { %>
      <div class="empty-state">
        <p>Nenhuma receita corresponde aos filtros escolhidos.</p>
        <a href="/receitas" class="btn-primary">Limpar filtros</a>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table class="table-crud">
          <thead>
            <tr>
              <th>#</th>
              <th>Nome</th>
              <th>Tipo</th>
              <th>Data</th>
              <th>Custo</th>
              <th>Descrição</th>
              <th class="th-actions">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% receitas.forEach(function (r) { %>
              <tr>
                <td><%= r.id %></td>
                <td><strong><%= r.nome %></strong></td>
                <td><span class="badge badge-<%= r.tipo_receita %>"><%= r.tipo_receita %></span></td>
                <td><%= formatDateBR(r.data_registro) %></td>
                <td>R$ <%= Number(r.custo).toFixed(2).replace(".", ",") %></td>
                <td class="desc"><%= r.descricao || "—" %></td>
                <td class="td-actions">
                  <div class="action-btns">
                    <a href="/receitas/<%= r.id %>/editar" class="btn-ghost btn-sm btn-icon" aria-label="Editar receita" title="Editar">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5Z"/></svg>
                    </a>
                    <form method="post" action="/receitas/<%= r.id %>/excluir" class="inline-form" onsubmit="return confirm('Excluir esta receita?');">
                      <button type="submit" class="btn-danger btn-sm btn-icon" aria-label="Excluir receita" title="Excluir">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M10 11v6M14 11v6"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>
